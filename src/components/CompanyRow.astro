---
import type { CareerAtlasCompanyNode } from "../data/projects";
import ExpandableDetailPanel from "./ExpandableDetailPanel.astro";
import ProjectBar from "./ProjectBar.astro";
import { toBasePath } from "../utils/paths";

interface Props {
  company: CareerAtlasCompanyNode;
}

const { company } = Astro.props;

function resolveLogoSrc(src: string): string {
  if (/^(https?:)?\/\//.test(src) || src.startsWith("data:")) {
    return src;
  }

  return toBasePath(src.startsWith("/") ? src : `/${src}`);
}
---

<article id={company.id} class="company-row" data-company-row data-expanded="false" style={`--company-color: ${company.color};`}>
  <div class="company-row__meta">
    <button
      type="button"
      class="company-row__toggle"
      data-company-toggle
      data-company-id={company.id}
      aria-controls={`${company.id}-panel`}
      aria-expanded="false"
    >
      <span class="company-row__name">{company.organization}</span>
      <span class="company-row__years text-mono">{company.rangeLabel}</span>
    </button>
    <p class="company-row__summary">{company.roleSummary}</p>
    {company.logo && (
      <div class="company-row__meta-logo-wrap">
        <img
          class="company-row__meta-logo"
          src={resolveLogoSrc(company.logo.src)}
          alt={company.logo.alt}
          loading="lazy"
        />
      </div>
    )}
  </div>

  <div class="company-row__canvas">
    <div class="company-row__track" aria-hidden="true">
      <button
        type="button"
        class="company-row__bar"
        data-company-toggle
        data-company-id={company.id}
        aria-controls={`${company.id}-panel`}
        aria-expanded="false"
        style={`left: ${company.offsetPct}%; width: ${company.widthPct}%;`}
      >
        <span>{company.organization}</span>
        {company.isActive && <span class="company-row__bar-live text-mono">Present</span>}
        <span class="company-row__preview" aria-hidden="true">
          <strong>{company.organization}</strong>
          <span>{company.rangeLabel} • {company.projectCount} projects</span>
          <span>{company.longSummary || company.summary}</span>
        </span>
      </button>
    </div>

    <ExpandableDetailPanel id={`${company.id}-panel`} title={`${company.organization} details`}>
      <p>{company.longSummary || company.summary}</p>
      {company.roles.length > 0 && (
        <p><span class="text-accent">Roles:</span> {company.roles.join(" / ")}</p>
      )}
      {company.achievements.length > 0 && (
        <p><span class="text-accent">Achievements:</span> {company.achievements.join(" ")}</p>
      )}
      <p><span class="text-accent">Projects:</span> {company.projectCount}</p>
    </ExpandableDetailPanel>

    <ul class="company-row__projects" aria-label={`${company.organization} projects`}>
      {company.projects.map((project) => (
        <ProjectBar project={project} color={company.color} />
      ))}
    </ul>
  </div>
</article>

<style>
  .company-row {
    display: grid;
    grid-template-columns: minmax(10rem, var(--atlas-meta-col)) minmax(var(--atlas-canvas-min), 1fr);
    gap: var(--atlas-grid-gap);
    align-items: start;
    border-top: 1px solid color-mix(in srgb, var(--color-border), white 5%);
    padding-top: var(--space-md);
    margin-top: var(--space-md);
  }

  .company-row__meta {
    position: sticky;
    left: 0;
    z-index: 3;
    background: linear-gradient(90deg, rgba(12, 20, 17, 0.95), rgba(12, 20, 17, 0.7), transparent);
    padding-right: var(--space-sm);
  }

  .company-row__toggle {
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    text-align: left;
    width: 100%;
    display: grid;
    gap: 0.2rem;
    padding: 0;
  }

  .company-row__toggle:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .company-row__name {
    font-family: var(--font-heading);
    font-size: 0.93rem;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--company-color), white 30%);
  }

  .company-row__years {
    font-size: 0.61rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .company-row__summary {
    margin: 0.45rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.79rem;
    line-height: 1.55;
  }

  .company-row__meta-logo-wrap {
    margin-top: var(--space-sm);
  }

  .company-row__meta-logo {
    display: block;
    width: auto;
    max-width: min(160px, 100%);
    max-height: 48px;
    object-fit: contain;
  }

  .company-row__canvas {
    position: relative;
  }

  .company-row__track {
    position: relative;
    height: 1.55rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-border), white 3%);
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 0 72px,
        rgba(255, 255, 255, 0.04) 72px 73px
      ),
      color-mix(in srgb, var(--color-bg-card), black 14%);
    overflow: visible;
  }

  .company-row__bar {
    position: absolute;
    top: 2px;
    bottom: 2px;
    min-width: 10px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--company-color), black 15%);
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--company-color), black 22%),
      color-mix(in srgb, var(--company-color), white 12%)
    );
    color: color-mix(in srgb, var(--company-color), white 82%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition: box-shadow var(--transition-base), transform var(--transition-fast);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    text-shadow: 0 0 8px color-mix(in srgb, var(--company-color), black 45%);
  }

  .company-row__bar > span:first-child {
    color: #050505;
    font-weight: 800;
    text-shadow: none;
  }

  .company-row__bar:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .company-row__bar:hover,
  .company-row[data-expanded="true"] .company-row__bar {
    box-shadow: 0 0 20px color-mix(in srgb, var(--company-color), transparent 55%);
    transform: translateY(-1px);
    filter: saturate(1.12) brightness(1.04);
  }

  .company-row__bar-live {
    color: color-mix(in srgb, var(--color-success), white 16%);
    text-shadow: 0 0 10px rgba(74, 222, 128, 0.4);
    font-size: 0.54rem;
    font-weight: 700;
  }

  .company-row__preview {
    pointer-events: none;
    position: absolute;
    left: 50%;
    bottom: calc(100% + 0.55rem);
    z-index: 14;
    width: min(30rem, 56vw);
    min-width: 16rem;
    border: 1px solid color-mix(in srgb, var(--company-color), transparent 40%);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-bg), black 14%);
    box-shadow: var(--shadow-card);
    color: var(--color-text);
    display: grid;
    gap: 0.3rem;
    padding: 0.5rem 0.65rem;
    opacity: 0;
    transform: translate(-50%, 4px);
    transition: opacity var(--transition-fast), transform var(--transition-fast), filter var(--transition-fast);
    filter: saturate(0.95);
  }

  .company-row__preview strong {
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--company-color), white 65%);
  }

  .company-row__preview span {
    font-size: 0.72rem;
    line-height: 1.45;
    color: var(--color-text-muted);
    text-transform: none;
    letter-spacing: normal;
    font-weight: 500;
  }

  .company-row__bar:hover .company-row__preview,
  .company-row__bar:focus-visible .company-row__preview {
    opacity: 1;
    transform: translate(-50%, 0);
    filter: saturate(1);
  }

  .company-row__projects {
    list-style: none;
    display: grid;
    gap: var(--space-sm);
    margin: 0;
    padding: 0;
    margin-top: var(--space-md);
    overflow: hidden;
  }

  .company-row[data-expanded="false"] .company-row__projects {
    display: none;
  }

  :global(.career-atlas[data-view="overview"]) .company-row {
    grid-template-columns: 1fr;
    gap: 0;
    padding-top: 0.55rem;
    margin-top: 0.55rem;
  }

  :global(.career-atlas[data-view="overview"]) .company-row__meta {
    display: none;
  }

  :global(.career-atlas[data-view="overview"]) .company-row:first-child {
    margin-top: 0.2rem;
  }

  .company-row[data-expanded="false"] .company-row__projects [data-major="false"] {
    display: none;
  }

  @media (max-width: 640px) {
    .company-row {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
      padding-top: var(--space-lg);
    }

    .company-row__meta {
      position: static;
      background: none;
      padding-right: 0;
    }

    .company-row__track {
      height: auto;
      background: transparent;
      border: 0;
    }

    .company-row__bar {
      position: relative;
      width: 100% !important;
      left: 0 !important;
      min-height: 2.1rem;
    }

    .company-row__preview {
      display: none;
    }

    .company-row__projects {
      opacity: 1;
      max-height: none;
      margin-top: var(--space-sm);
    }
  }
</style>
