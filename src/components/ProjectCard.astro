---
// ProjectCard.astro — Reusable project card component
import {
  projectStatusColors,
  projectStatusLabels,
  type Project,
} from "../data/projects";
import { toBasePath } from "../utils/paths";

interface Props {
  project: Project;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
const projectPath = toBasePath(`/projects/${project.slug}`);
const primaryLink = project.links?.[0];

function resolveSrc(src: string): string {
  if (/^(https?:)?\/\//.test(src) || src.startsWith("data:")) {
    return src;
  }

  return toBasePath(src.startsWith("/") ? src : `/${src}`);
}

const firstVideo = project.media?.find((item) => item.type === "video");
const firstImage = project.media?.find((item) => item.type === "image");

const previewMedia = firstVideo?.poster
  ? {
      type: "video-poster" as const,
      src: resolveSrc(firstVideo.poster),
      alt: `${project.title} video preview`,
    }
  : firstVideo
    ? {
        type: "video" as const,
        src: resolveSrc(firstVideo.src),
      }
    : firstImage
    ? {
        type: "image" as const,
        src: resolveSrc(firstImage.src),
        alt: firstImage.alt,
      }
    : undefined;
---

<article class={`project-card ${featured ? "project-card--featured" : ""}`}>
  <a href={projectPath} class="project-card__main-link" aria-label={`View project: ${project.title}`}>
    <div class="project-card__header">
      <div class="project-card__meta">
        <span class={`badge ${projectStatusColors[project.status]}`}>{projectStatusLabels[project.status]}</span>
        {project.organization && (
          <span class="project-card__org text-mono text-muted">{project.organization}</span>
        )}
      </div>
      <span class="project-card__arrow" aria-hidden="true">→</span>
    </div>

    {previewMedia && (
      <div class="project-card__media">
        {previewMedia.type === "video-poster" ? (
          <>
            <img src={previewMedia.src} alt={previewMedia.alt} loading="lazy" decoding="async" />
            <span class="project-card__media-chip">Video</span>
          </>
        ) : previewMedia.type === "video" ? (
          <>
            <video
              src={previewMedia.src}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-label={`${project.title} video preview`}
            ></video>
            <span class="project-card__media-chip">Video</span>
          </>
        ) : (
          <img src={previewMedia.src} alt={previewMedia.alt} loading="lazy" decoding="async" />
        )}
      </div>
    )}

    <h3 class="project-card__title">{project.title}</h3>

    {project.timeframe && (
      <p class="project-card__timeframe text-mono text-muted">{project.timeframe}</p>
    )}

    <p class="project-card__summary">{project.summary}</p>

    <div class="project-card__tags">
      {project.tags.slice(0, 4).map((tag) => (
        <span class="badge badge-purple">{tag}</span>
      ))}
      {project.tags.length > 4 && (
        <span class="badge badge-gray">+{project.tags.length - 4}</span>
      )}
    </div>
  </a>

  <div class="project-card__actions">
    {primaryLink ? (
      <a
        href={primaryLink.url}
        class="btn btn-outline btn-sm"
        target="_blank"
        rel="noopener noreferrer"
      >
        {primaryLink.label} ↗
      </a>
    ) : (
      <a href={projectPath} class="btn btn-ghost btn-sm">View Details</a>
    )}
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.01), transparent 28%),
      var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: border-color var(--transition-base), box-shadow var(--transition-base),
      background var(--transition-base), transform var(--transition-base);
    position: relative;
    overflow: hidden;
    height: 100%;
  }

  .project-card__main-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    flex: 1;
    position: relative;
    z-index: 1;
  }

  /* Corner accent */
  .project-card::before {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    width: 88px;
    height: 88px;
    background: linear-gradient(135deg, rgba(201, 122, 43, 0.22), transparent 62%);
    clip-path: polygon(100% 0, 0 0, 100% 100%);
    transition: opacity var(--transition-base), transform var(--transition-base);
    opacity: 0.65;
  }

  .project-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--shadow-card-hover), var(--glow-accent);
    background: var(--color-bg-card-hover);
    transform: translateY(-2px);
  }

  .project-card:hover::before {
    opacity: 1;
    transform: scale(1.04);
  }

  .project-card--featured {
    border-color: rgba(124, 211, 137, 0.24);
  }

  .project-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    position: relative;
    z-index: 1;
  }

  .project-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .project-card__org {
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .project-card__arrow {
    color: var(--color-accent);
    font-size: 1rem;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity var(--transition-base), transform var(--transition-base);
    flex-shrink: 0;
  }

  .project-card:hover .project-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .project-card__title {
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text-heading);
    line-height: 1.3;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .project-card__media {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg);
  }

  .project-card__media img,
  .project-card__media video {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .project-card__media-chip {
    position: absolute;
    bottom: var(--space-sm);
    left: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.45rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    background: rgba(0, 0, 0, 0.55);
    color: var(--color-text);
  }

  .project-card__timeframe {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    margin: 0;
    position: relative;
    z-index: 1;
  }

  .project-card__summary {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
    position: relative;
    z-index: 1;
    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: auto;
    position: relative;
    z-index: 1;
  }

  .project-card__actions {
    display: flex;
    justify-content: flex-start;
    position: relative;
    z-index: 1;
  }

  .project-card__actions .btn {
    text-decoration: none;
  }
</style>
