---
// SectionHeader.astro — Reusable section heading block
interface Props {
  label?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
}

const { label, title, subtitle, centered = false } = Astro.props;
---

<div class={`section-header ${centered ? "section-header--centered" : ""}`}>
  {label && <p class="section-label">{label}</p>}
  <span class="accent-line"></span>
  <h2>{title}</h2>
  {subtitle && <p class="section-header__subtitle">{subtitle}</p>}
</div>

<style>
  .section-header {
    margin-bottom: var(--space-2xl);
    position: relative;
  }

  .section-header::after {
    content: "";
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 140px;
    height: 1px;
    background: linear-gradient(90deg, rgba(124, 211, 137, 0.24), rgba(201, 122, 43, 0.22), transparent);
    transform: translateY(-1.4rem);
  }

  .section-header--centered {
    text-align: center;
  }

  .section-header--centered::after {
    left: 50%;
    transform: translate(-50%, -1.4rem);
  }

  .section-header--centered .accent-line {
    margin-inline: auto;
  }

  .section-header__subtitle {
    margin-top: var(--space-md);
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 60ch;
    line-height: 1.7;
  }

  .section-header--centered .section-header__subtitle {
    margin-inline: auto;
  }
</style>
