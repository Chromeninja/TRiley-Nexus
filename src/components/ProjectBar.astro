---
import type { CareerAtlasProjectNode } from "../data/projects";
import { toBasePath } from "../utils/paths";
import ExpandableDetailPanel from "./ExpandableDetailPanel.astro";

interface Props {
  project: CareerAtlasProjectNode;
  color: string;
}

const { project, color } = Astro.props;
const projectHref = toBasePath(`/projects/${project.slug}`);
---

<li
  id={project.id}
  class="project-item"
  data-project-item
  data-major={project.isMajor ? "true" : "false"}
  data-expanded="false"
>
  <button
    type="button"
    class="project-item__bar"
    data-project-toggle
    data-project-id={project.id}
    aria-controls={`${project.id}-panel`}
    aria-expanded="false"
    style={`left: ${project.offsetPct}%; width: ${project.widthPct}%; --project-color: ${color};`}
  >
    <span class="project-item__title">{project.title}</span>
    <span class="project-item__meta text-mono">{project.startedAt} - {project.endedAt}</span>
    {project.isLive && <span class="project-item__live text-mono">Live</span>}
    <span class="project-item__preview" aria-hidden="true">
      <strong>{project.title}</strong>
      <span>{project.roleTitle} • {project.status}</span>
      <span>{project.summary}</span>
    </span>
  </button>

  <ExpandableDetailPanel id={`${project.id}-panel`} title={`${project.title} details`}>
    <p>{project.description || project.summary}</p>
    {project.outcomes.length > 0 && (
      <p><span class="text-accent">Outcomes:</span> {project.outcomes.join(" ")}</p>
    )}
    {project.tools.length > 0 && (
      <p><span class="text-accent">Tools:</span> {project.tools.join(" • ")}</p>
    )}
    <p>
      <span class="text-accent">Role:</span> {project.roleTitle}
      <span class="text-muted"> • </span>
      <span class="text-accent">Status:</span> {project.status}
      {project.mediaCount > 0 && (
        <>
          <span class="text-muted"> • </span>
          <span class="text-accent">Media:</span> {project.mediaCount}
        </>
      )}
    </p>
    <p>
      <a href={projectHref}>Open full project case study</a>
      {project.links.length > 0 && (
        <>
          <span class="text-muted"> • </span>
          <a href={project.links[0]?.url} rel="noopener noreferrer" target="_blank">{project.links[0]?.label}</a>
        </>
      )}
    </p>
  </ExpandableDetailPanel>
</li>

<style>
  .project-item {
    position: relative;
    min-height: 1.65rem;
  }

  .project-item__bar {
    position: absolute;
    top: 0;
    height: 1.25rem;
    min-width: 8px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--project-color), black 24%);
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--project-color), black 28%),
      color-mix(in srgb, var(--project-color), white 12%)
    );
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.45rem;
    padding: 0 0.5rem;
    cursor: pointer;
    transition: transform var(--transition-fast), box-shadow var(--transition-base), filter var(--transition-fast);
    color: color-mix(in srgb, var(--project-color), white 84%);
    overflow: visible;
    text-align: left;
    z-index: 2;
    text-shadow: 0 0 8px color-mix(in srgb, var(--project-color), black 40%);
  }

  .project-item__bar:focus-visible {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .project-item__bar:hover,
  .project-item[data-expanded="true"] .project-item__bar {
    transform: translateY(-1px);
    box-shadow: 0 0 18px color-mix(in srgb, var(--project-color), transparent 55%);
    filter: saturate(1.08);
  }

  .project-item__title {
    font-size: 0.66rem;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 18ch;
  }

  .project-item__meta {
    font-size: 0.56rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--project-color), white 70%);
    white-space: nowrap;
  }

  .project-item__live {
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-success), white 12%);
    text-shadow: 0 0 8px rgba(74, 222, 128, 0.4);
  }

  .project-item__preview {
    pointer-events: none;
    position: absolute;
    left: 0;
    top: calc(100% + 0.5rem);
    background: color-mix(in srgb, var(--color-bg), black 14%);
    border: 1px solid color-mix(in srgb, var(--project-color), transparent 45%);
    border-radius: var(--radius-sm);
    padding: 0.45rem 0.55rem;
    width: min(28rem, 48vw);
    color: var(--color-text);
    font-size: 0.72rem;
    line-height: 1.45;
    display: grid;
    gap: 0.28rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
    z-index: 12;
  }

  .project-item__preview strong {
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--project-color), white 68%);
  }

  .project-item__preview span {
    color: var(--color-text-muted);
    font-size: 0.72rem;
    line-height: 1.45;
    font-weight: 500;
    text-transform: none;
    letter-spacing: normal;
  }

  .project-item__bar:hover .project-item__preview {
    opacity: 1;
    transform: translateY(0);
  }

  .project-item :global(.expandable-detail) {
    position: relative;
    padding-top: 1.55rem;
  }

  @media (max-width: 640px) {
    .project-item__bar {
      position: relative;
      width: 100% !important;
      left: 0 !important;
      min-height: 2rem;
      height: auto;
      flex-wrap: wrap;
      padding-block: 0.42rem;
    }

    .project-item__preview {
      display: none;
    }

    .project-item :global(.expandable-detail) {
      padding-top: 0;
    }
  }
</style>
