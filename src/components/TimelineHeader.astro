---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<header class="atlas-header">
  <h3 class="atlas-header__title">{title}</h3>
  <p class="atlas-header__subtitle">{subtitle}</p>
</header>

<style>
  .atlas-header {
    display: grid;
    gap: var(--space-sm);
  }

  .atlas-header__title {
    margin: 0;
    font-size: clamp(1.05rem, 1.2vw, 1.28rem);
    letter-spacing: 0.04em;
  }

  .atlas-header__subtitle {
    margin: 0;
    color: var(--color-text-muted);
    max-width: 75ch;
    font-size: 0.92rem;
    line-height: 1.75;
  }
</style>
