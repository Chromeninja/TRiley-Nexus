---
// how-i-work.astro — Methodology & operating style page
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {
  aarIntro,
  aarQuestions,
  coreApproachParagraphs,
  toolchainGroups,
  workPrinciples,
  workStyleGroups,
} from "../data/howIWorkContent";
---

<Layout
  title="How I Work"
  description="My operating principles, methodology, and approach to solving complex operational and technical problems."
>
  <!-- Page Hero -->
  <PageHero
    label="// APPROACH"
    title="How I Work"
    subtitle="How I approach ambiguity, align teams, and turn hard problems into workable systems."
  />

  <!-- Core Approach -->
  <section class="section">
    <div class="container container--md">
      <SectionHeader label="// CORE APPROACH" title="The Core Approach" />
      <div class="prose">
        {coreApproachParagraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="section" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container">
      <SectionHeader label="// OPERATING PRINCIPLES" title="How I Think About Problems" />

      <div class="principles-grid">
        {workPrinciples.map((p) => (
          <div class="principle-card">
            <span class="principle-card__num text-mono text-accent">{p.num}</span>
            <div>
              <h3 class="principle-card__title">{p.title}</h3>
              <p class="principle-card__body">{p.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Working style -->
  <section class="section">
    <div class="container container--md">
      <SectionHeader label="// WORKING STYLE" title="Working Style" />

      <div class="style-cols">
        {workStyleGroups.map((group) => (
          <div class="style-col">
            <h3 class="style-col__title">
              <span class="text-accent">{group.icon}</span> {group.title}
            </h3>
            <ul class="style-list">
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tools I Use -->
  <section class="section" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container container--md">
      <SectionHeader label="// TOOLS & FRAMEWORKS" title="Tools & Frameworks I Use" />

      <div class="toolchain-grid">
        {toolchainGroups.map((group) => (
          <div class="toolchain-group">
            <h4 class="toolchain-group__label">{group.category}</h4>
            <div class="tag-cloud">
              {group.tools.map((tool) => (
                <span class="badge badge-cyan">{tool}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- After Action Review philosophy -->
  <section class="section">
    <div class="container container--sm">
      <SectionHeader label="// CONTINUOUS IMPROVEMENT" title="The After Action Review" centered />

      <div class="aar-panel">
        <p class="aar-panel__intro">
          {aarIntro}
        </p>

        <div class="aar-questions">
          {aarQuestions.map((item) => (
            <div class="aar-item">
              <p class="aar-item__q">{item.q}</p>
              <p class="aar-item__sub">{item.sub}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Principles */
  .principles-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .principle-card {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    align-items: start;
    transition: border-color var(--transition-base);
  }

  .principle-card:hover {
    border-color: var(--color-border-strong);
  }

  .principle-card__num {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    padding-top: 4px;
  }

  .principle-card__title {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
    color: var(--color-text-heading);
  }

  .principle-card__body {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* Working style */
  .style-cols {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-xl);
  }

  .style-col {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .style-col__title {
    font-size: 0.9rem;
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-heading);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .style-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .style-list li {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.55;
    padding-left: var(--space-md);
    position: relative;
  }

  .style-list li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.6rem;
    top: 4px;
  }

  /* Toolchain */
  .toolchain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-xl);
  }

  .toolchain-group {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .toolchain-group__label {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  /* AAR */
  .aar-panel {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
  }

  .aar-panel__intro {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
    font-size: 0.9375rem;
  }

  .aar-questions {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .aar-item {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .aar-item:last-child { border-bottom: none; }

  .aar-item__q {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    color: var(--color-text-heading);
    margin: 0;
  }

  .aar-item__sub {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
    font-family: var(--font-mono);
  }

  @media (max-width: 640px) {
    .principle-card,
    .style-col,
    .toolchain-group,
    .aar-panel {
      padding: var(--space-lg);
    }

    .principle-card {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .principle-card__num {
      padding-top: 0;
    }

    .aar-item {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }
  }
</style>
