---
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import CareerAtlas from "../../components/CareerAtlas.astro";
import CareerNarrativeExplorer from "../../components/CareerNarrativeExplorer.astro";
import CareerScrollTimeline from "../../components/CareerScrollTimeline.astro";
import CompanyTimeline from "../../components/CompanyTimeline.astro";
import LifeTimeline from "../../components/LifeTimeline.astro";
import TimelineViewSelector, {
  type TimelineViewMode,
} from "../../components/TimelineViewSelector.astro";
import {
  getCareerAtlasData,
  getCareerNarrativeData,
  getLifeTimelineEntries,
  parseProjectDateValue,
  getProjectOrganizationGroups,
  getProjects,
  type Project,
  type ProjectOrganizationGroup,
} from "../../data/projects";

interface TimelineMonthGroup {
  key: string;
  month: number;
  monthLabel: string;
  projects: Project[];
}

interface TimelineYearGroup {
  year: number;
  key: string;
  months: TimelineMonthGroup[];
}

const timelineViewModes: TimelineViewMode[] = [
  "gantt",
  "narrative",
  "scroll",
  "company",
  "life",
];

function resolveTimelineViewMode(value: string | null): TimelineViewMode {
  if (!value) {
    return "narrative";
  }

  const lowered = value.toLowerCase();
  return timelineViewModes.includes(lowered as TimelineViewMode)
    ? (lowered as TimelineViewMode)
    : "narrative";
}

const timelineView = resolveTimelineViewMode(
  Astro.url.searchParams.get("view"),
);

const monthLabelFormatter = new Intl.DateTimeFormat("en-US", { month: "long" });

function parseDateValue(value?: string): Date | undefined {
  if (!value) {
    return undefined;
  }

  const trimmed = value.trim();
  if (!trimmed) {
    return undefined;
  }

  return parseProjectDateValue(trimmed, "start");
}

function sortByOrderThenDate(a: Project, b: Project): number {
  const orderDelta = (a.order ?? 99) - (b.order ?? 99);
  if (orderDelta !== 0) {
    return orderDelta;
  }

  const aDate = parseDateValue(a.startedAt)?.getTime() ?? 0;
  const bDate = parseDateValue(b.startedAt)?.getTime() ?? 0;
  return bDate - aDate;
}

const shouldShowGantt = timelineView === "gantt";
const shouldShowNarrative = timelineView === "narrative";
const shouldShowScroll = timelineView === "scroll";
const shouldShowCompany = timelineView === "company";
const shouldShowLife = timelineView === "life";

const atlasData = await getCareerAtlasData();
const narrativeData = await getCareerNarrativeData();

let currentProjects: Project[] = [];
let yearGroups: TimelineYearGroup[] = [];

const projects = await getProjects();
const activeStatuses = new Set(["active", "concept"]);

currentProjects = projects
  .filter((project) => activeStatuses.has(project.status))
  .sort(sortByOrderThenDate);

const historicalProjects = projects.filter(
  (project) => !activeStatuses.has(project.status),
);
const yearBucket = new Map<number, Map<number, Project[]>>();

for (const project of historicalProjects) {
  const parsedStart = parseDateValue(project.startedAt);
  if (!parsedStart) {
    continue;
  }

  const year = parsedStart.getFullYear();
  const month = parsedStart.getMonth();

  if (!yearBucket.has(year)) {
    yearBucket.set(year, new Map<number, Project[]>());
  }

  const monthBucket = yearBucket.get(year);
  if (!monthBucket) {
    continue;
  }

  if (!monthBucket.has(month)) {
    monthBucket.set(month, []);
  }

  monthBucket.get(month)?.push(project);
}

yearGroups = [...yearBucket.entries()]
  .sort(([yearA], [yearB]) => yearB - yearA)
  .map(([year, monthMap]) => {
    const months: TimelineMonthGroup[] = [...monthMap.entries()]
      .sort(([monthA], [monthB]) => monthB - monthA)
      .map(([month, monthProjects]) => ({
        key: `month-${year}-${String(month + 1).padStart(2, "0")}`,
        month,
        monthLabel: monthLabelFormatter.format(new Date(year, month, 1)),
        projects: monthProjects.sort(sortByOrderThenDate),
      }));

    return {
      year,
      key: `year-${year}`,
      months,
    };
  });

const organizationGroups = await getProjectOrganizationGroups();
const companyTimelineGroups = organizationGroups
  .filter(
    (
      group,
    ): group is ProjectOrganizationGroup & {
      timeline: NonNullable<ProjectOrganizationGroup["timeline"]>;
    } => Boolean(group.timeline),
  )
  .sort(
    (groupA, groupB) =>
      groupA.timeline.rangeStart.getTime() -
      groupB.timeline.rangeStart.getTime(),
  );

const lifeTimelineEntries = await getLifeTimelineEntries();
---

<Layout
  title="My Career"
  description="Unified career timeline hub with selectable narrative, gantt, scroll, company, and life timeline views."
>
  <section class="section">
    <div class="container">
      <SectionHeader
        label="// MY CAREER"
        title="My Career"
        subtitle="Use the selector to switch between narrative, gantt, scroll, company, and life timeline views."
      />

      <TimelineViewSelector currentView={timelineView} />

      {
        narrativeData && (
          <div
            class={`career-view-panel ${shouldShowNarrative ? "" : "is-hidden"}`}
            data-career-view-panel="narrative"
          >
            <CareerNarrativeExplorer
              data={narrativeData}
              label="// CAREER SYSTEM"
              title="Explore the companies, systems, and programs behind the work"
              subtitle="Expand each company to inspect projects, roles, and execution context in-place."
              initialOpenCompanyCount={1}
            />
          </div>
        )
      }

      <div
        class={`career-view-panel ${shouldShowGantt ? "" : "is-hidden"}`}
        data-career-view-panel="gantt"
      >
        {
          atlasData ? (
            <CareerAtlas data={atlasData} />
          ) : (
            <div class="panel career-view-empty">
              <p class="text-muted">
                Gantt atlas data appears once dated company and project entries
                are available.
              </p>
            </div>
          )
        }
      </div>

      <div
        class={`career-view-panel ${shouldShowScroll ? "" : "is-hidden"}`}
        data-career-view-panel="scroll"
      >
        <CareerScrollTimeline
          currentProjects={currentProjects}
          yearGroups={yearGroups}
        />
      </div>

      <div
        class={`career-view-panel career-company-view ${shouldShowCompany ? "" : "is-hidden"}`}
        data-career-view-panel="company"
      >
        {
          companyTimelineGroups.length > 0 ? (
            companyTimelineGroups.map((group) => (
              <article class="panel career-company-view__item">
                <header class="career-company-view__header">
                  <p class="text-mono text-accent career-company-view__label">
                    {group.timeRangeLabel ?? group.timeline.rangeLabel}
                  </p>
                  <h2>{group.organization}</h2>
                  {group.companySummary && (
                    <p class="text-muted">{group.companySummary}</p>
                  )}
                </header>
                <CompanyTimeline timeline={group.timeline} />
              </article>
            ))
          ) : (
            <div class="panel career-view-empty">
              <p class="text-muted">
                Company timelines appear once organization timeline data is
                available.
              </p>
            </div>
          )
        }
      </div>

      <div
        class={`career-view-panel ${shouldShowLife ? "" : "is-hidden"}`}
        data-career-view-panel="life"
      >
        <LifeTimeline entries={lifeTimelineEntries} />
      </div>

      <p class="career-view-helper text-muted text-mono">
        Shareable links use query mode: /career?view=narrative,
        /career?view=gantt, /career?view=scroll, /career?view=company,
        /career?view=life
      </p>
    </div>
  </section>

  <script>
    (() => {
      const validModes = new Set([
        "gantt",
        "narrative",
        "scroll",
        "company",
        "life",
      ]);
      const selectorOptions = Array.from(
        document.querySelectorAll<HTMLAnchorElement>(
          ".timeline-view-selector__option[data-view-mode]",
        ),
      );
      const viewPanels = Array.from(
        document.querySelectorAll<HTMLElement>("[data-career-view-panel]"),
      );

      if (selectorOptions.length === 0 || viewPanels.length === 0) {
        return;
      }

      const resolveMode = (value: string | null): string => {
        if (!value) {
          return "narrative";
        }

        const lowered = value.toLowerCase();
        return validModes.has(lowered) ? lowered : "narrative";
      };

      const setActiveMode = (mode: string | null): string => {
        const resolvedMode = resolveMode(mode);

        viewPanels.forEach((panel) => {
          const panelMode = panel.getAttribute("data-career-view-panel");
          const isActive = panelMode === resolvedMode;
          panel.classList.toggle("is-hidden", !isActive);
          panel.toggleAttribute("hidden", !isActive);
        });

        selectorOptions.forEach((option) => {
          const optionMode = option.getAttribute("data-view-mode");
          const isActive = optionMode === resolvedMode;
          option.classList.toggle("is-active", isActive);
          option.setAttribute("data-active", isActive ? "true" : "false");
          option.setAttribute("aria-selected", isActive ? "true" : "false");
          if (isActive) {
            option.setAttribute("aria-current", "page");
          } else {
            option.removeAttribute("aria-current");
          }
        });

        return resolvedMode;
      };

      const applyModeFromUrl = () => {
        const mode = new URL(window.location.href).searchParams.get("view");
        setActiveMode(mode);
      };

      selectorOptions.forEach((option) => {
        option.addEventListener("click", (event) => {
          if (event.defaultPrevented) {
            return;
          }

          if (
            event.button !== 0 ||
            event.metaKey ||
            event.ctrlKey ||
            event.shiftKey ||
            event.altKey
          ) {
            return;
          }

          const target = event.currentTarget;
          if (!(target instanceof HTMLAnchorElement)) {
            return;
          }

          const targetMode = target.getAttribute("data-view-mode");
          const resolvedMode = setActiveMode(targetMode);
          const nextUrl = new URL(target.href, window.location.origin);
          nextUrl.searchParams.set("view", resolvedMode);
          window.history.pushState(
            {},
            "",
            `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`,
          );
          event.preventDefault();
        });
      });

      window.addEventListener("popstate", applyModeFromUrl);
      applyModeFromUrl();
    })();
  </script>
</Layout>

<style>
  .career-view-panel {
    margin-top: var(--space-lg);
  }

  .career-view-panel.is-hidden {
    display: none;
  }

  .career-view-helper {
    margin: var(--space-md) 0 0;
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .career-view-empty {
    margin-top: var(--space-lg);
  }

  .career-view-empty p {
    margin: 0;
  }

  .career-company-view {
    display: grid;
    gap: var(--space-md);
  }

  .career-company-view__item {
    display: grid;
    gap: var(--space-md);
  }

  .career-company-view__header {
    display: grid;
    gap: var(--space-xs);
  }

  .career-company-view__header h2,
  .career-company-view__header p {
    margin: 0;
  }

  .career-company-view__label {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>
