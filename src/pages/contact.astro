---
// contact.astro — Contact page
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SocialIcon from "../components/SocialIcon.astro";
---

<Layout
  title="Contact"
  description="Get in touch with T.Riley — open to roles, collaborations, and conversations about systems, operations, and building things."
>
  <!-- Page Hero -->
  <PageHero
    label="// CONTACT"
    title="Get in Touch"
    subtitle="I'm open to conversations about roles, collaborations, and meaningful systems work. Reach out through any of the channels below."
  />

  <section class="section">
    <div class="container">
      <div class="contact-layout">

        <!-- Contact options -->
        <div class="contact-cards">
          <SectionHeader label="// WAYS TO REACH ME" title="Connect With Me" />

          <div class="channel-list">
            <!-- Email -->
            <a href="mailto:t.riley.garrett@gmail.com" class="channel-card">
              <div class="channel-card__icon">
                <SocialIcon kind="email" size={24} />
              </div>
              <div>
                <p class="channel-card__label text-mono">Email</p>
                <p class="channel-card__value">t.riley.garrett@gmail.com</p>
                <p class="channel-card__hint text-muted">Best for professional inquiries and opportunities</p>
              </div>
              <span class="channel-card__arrow text-accent" aria-hidden="true">→</span>
            </a>

            <!-- LinkedIn -->
            <a href="https://www.linkedin.com/in/trileygarrett/" target="_blank" rel="noopener noreferrer" class="channel-card">
              <div class="channel-card__icon">
                <SocialIcon kind="linkedin" size={24} />
              </div>
              <div>
                <p class="channel-card__label text-mono">LinkedIn</p>
                <p class="channel-card__value">linkedin.com/in/trileygarrett</p>
                <p class="channel-card__hint text-muted">Professional network and career history</p>
              </div>
              <span class="channel-card__arrow text-accent" aria-hidden="true">↗</span>
            </a>

            <!-- GitHub -->
            <a href="https://github.com/Chromeninja" target="_blank" rel="noopener noreferrer" class="channel-card">
              <div class="channel-card__icon">
                <SocialIcon kind="github" size={24} />
              </div>
              <div>
                <p class="channel-card__label text-mono">GitHub</p>
                <p class="channel-card__value">github.com/Chromeninja</p>
                <p class="channel-card__hint text-muted">Selected builds, tooling, and project history</p>
              </div>
              <span class="channel-card__arrow text-accent" aria-hidden="true">↗</span>
            </a>
          </div>
        </div>

        <!-- Response expectations -->
        <aside class="contact-aside">
          <div class="response-panel">
            <h2 class="response-panel__title">
              <span class="text-mono text-accent">// </span>What to Expect
            </h2>

            <div class="response-items">
              <div class="response-item">
                <span class="response-item__label text-mono text-accent">Response time</span>
                <p>I typically respond to email inquiries within 1–2 business days. LinkedIn messages may take a bit longer.</p>
              </div>

              <div class="response-item">
                <span class="response-item__label text-mono text-accent">Best for</span>
                <p>Job opportunities, collaboration proposals, interesting problems, and thoughtful conversations.</p>
              </div>

              <div class="response-item">
                <span class="response-item__label text-mono text-accent">Not a fit</span>
                <p>Generic outreach, spray-and-pray recruiting messages, or anything that opens with "we have an exciting opportunity."</p>
              </div>
            </div>
          </div>

          <div class="status-panel">
            <div class="status-row">
              <span class="status-dot-sm" aria-hidden="true"></span>
              <span class="text-mono" style="font-size: 0.8rem; letter-spacing: 0.06em;">
                Status: <span class="text-accent">Open to opportunities</span>
              </span>
            </div>
            <p class="status-note text-muted">
              Actively considering TPM, operations leadership, and systems enablement roles.
              Remote-first preferred.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Layout */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--space-3xl);
    align-items: start;
  }

  /* Channel cards */
  .channel-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .channel-card {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    align-items: center;
    gap: var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--transition-base), background var(--transition-base),
      box-shadow var(--transition-base);
  }

  .channel-card:hover {
    border-color: var(--color-border-strong);
    background: var(--color-bg-card-hover);
    box-shadow: var(--glow-accent);
    color: var(--color-text);
  }

  .channel-card__icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--color-accent-dim);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .channel-card__label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 2px;
  }

  .channel-card__value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-heading);
    margin-bottom: var(--space-xs);
  }

  .channel-card__hint {
    font-size: 0.8rem;
    line-height: 1.4;
    margin: 0;
  }

  .channel-card__arrow {
    font-size: 1.25rem;
    transition: transform var(--transition-base);
  }

  .channel-card:hover .channel-card__arrow {
    transform: translateX(3px);
  }

  /* Aside */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    position: sticky;
    top: calc(var(--nav-height) + var(--space-xl));
  }

  .response-panel {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .response-panel__title {
    font-size: 1rem;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .response-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .response-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .response-item__label {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .response-item p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Status panel */
  .status-panel {
    background: rgba(16, 185, 129, 0.05);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .status-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .status-dot-sm {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse-glow 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .status-note {
    font-size: 0.8125rem;
    line-height: 1.55;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-aside {
      position: static;
      order: -1;
    }
  }

  @media (max-width: 560px) {
    .channel-card {
      grid-template-columns: 40px 1fr;
      gap: var(--space-md);
      padding: var(--space-lg);
    }

    .channel-card__arrow {
      display: none;
    }

    .channel-card__value {
      overflow-wrap: anywhere;
    }

    .response-panel,
    .status-panel {
      padding: var(--space-lg);
    }
  }
</style>
