---
// index.astro — Homepage
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { homePrinciples, homeStats } from "../data/homeContent";
import { coreStrengths } from "../data/skills";
import { toBasePath } from "../utils/paths";
import { siteConfig } from "../data/siteConfig";
---

<Layout
  title={siteConfig.site.baseTitle}
  description={siteConfig.home.metaDescription}
>
  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="hero">
    <div class="container">
      <div class="hero__grid">
        <div class="hero__content animate-fade-up">
          <p class="hero__eyebrow section-label">{siteConfig.home.hero.eyebrow}</p>
          <h1 class="hero__headline">
            {siteConfig.home.hero.headlineLead}
            <span class="hero__headline-accent"> {siteConfig.home.hero.headlineAccent}</span>
            {siteConfig.home.hero.headlineTail}
          </h1>
          <p class="hero__subtext">
            {siteConfig.home.hero.subtext}
          </p>
          <p class="hero__supporting-text">
            {siteConfig.home.hero.supportingText}
          </p>
          <div class="hero__actions">
            <a href={toBasePath(siteConfig.home.hero.primaryAction.href)} class="btn btn-primary">{siteConfig.home.hero.primaryAction.label}</a>
            <a href={toBasePath(siteConfig.home.hero.secondaryAction.href)} class="btn btn-outline">{siteConfig.home.hero.secondaryAction.label}</a>
          </div>
        </div>

        <div class="hero__signal panel animate-fade-up delay-200" aria-label="Core operating zones">
          <div class="hero__signal-head">
            <p class="hero__signal-label text-mono">FIELD MAP // ORBITAL SYSTEM</p>
            <span class="hero__signal-status">Active</span>
          </div>

          <div class="hero__signal-core">
            <div class="hero__signal-node hero__signal-node--center">
              <span class="hero__signal-node-title">Innovation Programs</span>
              <span class="hero__signal-node-text">Strategy, coordination, execution</span>
            </div>
            <div class="hero__signal-node hero__signal-node--left">
              <span class="hero__signal-node-title">Process Design</span>
              <span class="hero__signal-node-text">Clarity, cadence, accountability</span>
            </div>
            <div class="hero__signal-node hero__signal-node--right">
              <span class="hero__signal-node-title">Technical Enablement</span>
              <span class="hero__signal-node-text">Automation, tooling, operating leverage</span>
            </div>
          </div>

          <div class="hero__signal-metrics" aria-hidden="true">
            <div class="hero__signal-metric">
              <span class="hero__signal-value">People</span>
              <span class="hero__signal-caption">Cross-functional alignment</span>
            </div>
            <div class="hero__signal-metric">
              <span class="hero__signal-value">Process</span>
              <span class="hero__signal-caption">Operational repeatability</span>
            </div>
            <div class="hero__signal-metric">
              <span class="hero__signal-value">Systems</span>
              <span class="hero__signal-caption">Scaled execution infrastructure</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Background decoration -->
    <div class="hero__bg-grid" aria-hidden="true"></div>
  </section>

  <!-- ═══════════════════════════════════════════
       CORE STRENGTHS
  ═══════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <SectionHeader
        label="// CAPABILITIES"
        title="Core Strengths"
        subtitle="I work across the full operational stack — strategy, systems, people, and tools."
      />

      <div class="grid-3 strengths-grid">
        {coreStrengths.map((strength, i) => (
          <div class={`strength-card animate-fade-up delay-${Math.min((i + 1) * 100, 400)}`}>
            <span class="strength-card__icon" aria-hidden="true">{strength.icon}</span>
            <h3 class="strength-card__title">{strength.title}</h3>
            <p class="strength-card__desc">{strength.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CAREER TIMELINE HUB
  ═══════════════════════════════════════════ -->
  <section class="section" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container container--md">
      <SectionHeader
        label="// CAREER TIMELINE"
        title="Timeline views now live on the career page"
        subtitle="Choose narrative, gantt, scroll, company, or life timeline mode from one unified selector."
      />

      <div class="career-hub-card panel">
        <p class="career-hub-card__copy text-muted">
          The full timeline system has moved to a single hub so you can switch views without leaving context.
        </p>
        <div class="career-hub-card__actions">
          <a href={toBasePath("/career?view=narrative")} class="btn btn-primary">Open Narrative View</a>
          <a href={toBasePath("/career?view=gantt")} class="btn btn-outline">Open Gantt View</a>
          <a href={toBasePath("/career?view=scroll")} class="btn btn-ghost">Open Scroll View</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       HOW I WORK — TEASER
  ═══════════════════════════════════════════ -->
  <section class="section">
    <div class="container container--md">
      <SectionHeader
        label="// OPERATING PRINCIPLES"
        title="How I Work"
      />

      <div class="principles-list">
        {homePrinciples.map((principle) => (
          <div class="principle">
            <span class="principle__num text-mono text-accent">{principle.num}</span>
            <p class="principle__text">{principle.text}</p>
          </div>
        ))}
      </div>

      <div style="margin-top: var(--space-2xl);">
        <a href={toBasePath("/how-i-work")} class="btn btn-outline">Read More →</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PERSONAL INTRO
  ═══════════════════════════════════════════ -->
  <section class="section" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container container--md">
      <div class="intro-grid">
        <div class="intro__text">
          <p class="section-label">// BACKGROUND</p>
          <span class="accent-line"></span>
          <h2>A bit about me</h2>
          <p>
            I'm a systems-minded builder with a background spanning U.S. military service,
            technical program management, large-scale community operations, live events,
            and automation infrastructure.
          </p>
          <p>
            When I'm not building operational systems, I'm a father,
            a competitive Star Citizen player and community leader, and someone who
            thinks deeply about how organizations actually function at scale.
          </p>
          <p>
            I care about building things that work — not just on paper, but in the
            messy reality of people, pressure, and imperfect information.
          </p>
          <a href={toBasePath("/about")} class="btn btn-outline" style="margin-top: var(--space-md);">Full Background →</a>
        </div>

        <div class="intro__stats">
          {homeStats.map((stat) => (
            <div class="stat-card">
              <span class="stat-card__value">{stat.value}</span>
              <span class="stat-card__label">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA
  ═══════════════════════════════════════════ -->
  <section class="section section--sm">
    <div class="container">
      <div class="cta-panel">
        <p class="section-label">// WORK TOGETHER</p>
        <h2>Let's build something together.</h2>
        <p>
          I'm open to roles in technical program management, operations leadership,
          and innovation-focused systems work. If you're building something complex
          and need someone who can align people, process, and execution — reach out.
        </p>
        <div class="cta-panel__actions">
          <a href={toBasePath("/contact")} class="btn btn-primary">Get in Touch</a>
          <a href={toBasePath("/now")} class="btn btn-ghost">What I'm Working On</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-4xl);
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: var(--space-3xl);
    align-items: center;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-md);
  }

  .hero__headline {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.15;
    margin-bottom: var(--space-lg);
  }

  .hero__headline-accent {
    color: var(--color-accent);
    position: relative;
  }

  .hero__subtext {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 52ch;
    margin-bottom: var(--space-md);
  }

  .hero__supporting-text {
    color: var(--color-text);
    max-width: 56ch;
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero__signal {
    min-height: 420px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-xl);
    position: relative;
    background:
      radial-gradient(circle at top, rgba(87, 166, 255, 0.18), transparent 35%),
      radial-gradient(circle at 85% 20%, rgba(34, 211, 238, 0.14), transparent 28%),
      linear-gradient(145deg, rgba(6, 12, 24, 0.94), rgba(10, 20, 40, 0.94));
  }

  .hero__signal::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(87, 166, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(87, 166, 255, 0.05) 1px, transparent 1px);
    background-size: 30px 30px;
    mask-image: radial-gradient(circle at center, black 40%, transparent 100%);
    pointer-events: none;
  }

  .hero__signal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    position: relative;
    z-index: 1;
  }

  .hero__signal-label {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
  }

  .hero__signal-status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    border: 1px solid rgba(87, 166, 255, 0.28);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-heading);
    background: rgba(87, 166, 255, 0.08);
  }

  .hero__signal-status::before {
    content: "";
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--color-success);
    box-shadow: 0 0 14px rgba(87, 166, 255, 0.55);
  }

  .hero__signal-core {
    position: relative;
    display: grid;
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    z-index: 1;
  }

  .hero__signal-core::before,
  .hero__signal-core::after {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(87, 166, 255, 0.55), transparent);
  }

  .hero__signal-core::before {
    top: 24%;
    height: 32%;
  }

  .hero__signal-core::after {
    bottom: 18%;
    height: 22%;
  }

  .hero__signal-node {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    width: min(260px, 100%);
    padding: var(--space-md);
    border: 1px solid rgba(87, 166, 255, 0.16);
    border-radius: var(--radius-md);
    background: rgba(6, 13, 18, 0.68);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02);
  }

  .hero__signal-node--center {
    justify-self: center;
    width: min(290px, 100%);
    border-color: rgba(87, 166, 255, 0.28);
    box-shadow: 0 0 20px rgba(87, 166, 255, 0.12);
  }

  .hero__signal-node--left {
    justify-self: start;
  }

  .hero__signal-node--right {
    justify-self: end;
  }

  .hero__signal-node-title {
    font-family: var(--font-heading);
    font-size: 0.88rem;
    letter-spacing: 0.05em;
    color: var(--color-text-heading);
  }

  .hero__signal-node-text {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  .hero__signal-metrics {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-md);
  }

  .hero__signal-metric {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding-top: var(--space-md);
    border-top: 1px solid rgba(217, 119, 6, 0.28);
  }

  .hero__signal-value {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-heading);
  }

  .hero__signal-caption {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .hero__bg-grid {
    position: absolute;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(rgba(87, 166, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 211, 238, 0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
  }

  /* ── Strengths ── */
  .strength-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .strength-card:hover {
    border-color: var(--color-border-strong);
    box-shadow: var(--glow-accent);
  }

  .strength-card__icon {
    display: block;
    font-size: 1.5rem;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    line-height: 1;
  }

  .strength-card__title {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
    color: var(--color-text-heading);
  }

  .strength-card__desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Principles ── */
  .principles-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .principle {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: var(--space-md);
    align-items: start;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .principle:last-child { border-bottom: none; }

  .principle__num {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    padding-top: 3px;
  }

  .principle__text {
    color: var(--color-text);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Personal intro ── */
  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .intro__text p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .intro__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .stat-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .stat-card__value {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .stat-card__label {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .career-hub-card {
    display: grid;
    gap: var(--space-md);
  }

  .career-hub-card__copy {
    margin: 0;
  }

  .career-hub-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* ── CTA ── */
  .cta-panel {
    background: var(--color-bg-card);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: var(--radius-xl);
    padding: var(--space-3xl);
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: var(--glow-accent);
  }

  .cta-panel h2 {
    margin-block: var(--space-md);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
  }

  .cta-panel p {
    color: var(--color-text-muted);
    max-width: 55ch;
    margin-inline: auto;
    line-height: 1.7;
  }

  .cta-panel__actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
    margin-top: var(--space-xl);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .hero__signal {
      min-height: auto;
    }

    .hero {
      min-height: auto;
      padding-block: var(--space-3xl);
    }

    .intro-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero__signal {
      padding: var(--space-lg);
    }

    .hero__signal-head {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero__signal-node,
    .hero__signal-node--center,
    .hero__signal-node--left,
    .hero__signal-node--right {
      justify-self: stretch;
      width: 100%;
    }

    .hero__signal-metrics {
      grid-template-columns: 1fr;
    }

    .intro__stats {
      grid-template-columns: 1fr 1fr;
    }

    .cta-panel {
      padding: var(--space-2xl) var(--space-lg);
    }
  }
</style>
