---
// about.astro — About page
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { skillGroups } from "../data/skills";
import { toBasePath } from "../utils/paths";
import { siteConfig } from "../data/siteConfig";
import {
  aboutAdditionalMedia,
  aboutBackgroundParagraphs,
  aboutProfileMedia,
  aboutPersonalItems,
  aboutThinkItems,
  aboutValues,
} from "../data/aboutContent";

function resolveMediaSrc(src: string): string {
  if (/^(https?:)?\/\//.test(src) || src.startsWith("data:")) {
    return src;
  }

  return toBasePath(src.startsWith("/") ? src : `/${src}`);
}

const resumeConfig = siteConfig.about.resume;
const resumePath = resumeConfig
  ? resolveMediaSrc(resumeConfig.filePath)
  : undefined;
---

<Layout title="About" description={siteConfig.about.metaDescription}>
  <!-- Page Hero -->
  <PageHero
    label="// PROFILE"
    title="About Me"
    subtitle="A program leader and systems-minded builder working at the intersection of people, process, and technology."
  >
    {
      aboutProfileMedia && (
        <figure
          slot="aside"
          class="profile-photo panel"
          aria-label="Profile photo"
        >
          <img
            src={resolveMediaSrc(aboutProfileMedia.src)}
            alt={aboutProfileMedia.alt}
            loading="lazy"
          />
        </figure>
      )
    }
  </PageHero>

  <!-- Background -->
  <section class="section">
    <div class="container">
      <SectionHeader label="// ORIGIN STORY" title="Background" />

      <div class="prose">
        {aboutBackgroundParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <!-- How I Think -->
  <section
    class="section"
    style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);"
  >
    <div class="container container--md">
      <SectionHeader label="// MENTAL MODELS" title="How I Think" />

      <div class="think-grid">
        {
          aboutThinkItems.map((item) => (
            <div class="think-card">
              <h3 class="think-card__title">{item.title}</h3>
              <p class="think-card__text">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="section">
    <div class="container">
      <SectionHeader label="// CAPABILITIES" title="Skills & Expertise" />

      <div class="skills-grid">
        {
          skillGroups.map((group) => (
            <div class="skill-group">
              <div class="skill-group__header">
                <span class="skill-group__icon text-accent" aria-hidden="true">
                  {group.icon}
                </span>
                <h3 class="skill-group__label">{group.label}</h3>
              </div>
              <ul class="skill-list">
                {group.skills.map((skill) => (
                  <li class="skill-item">
                    <span class="skill-item__dot" aria-hidden="true">
                      ▸
                    </span>
                    {skill}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Personal -->
  <section
    class="section"
    style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);"
  >
    <div class="container container--md">
      <SectionHeader label="// LIFE OUTSIDE WORK" title="Beyond Work" />

      <div class="personal-grid">
        {
          aboutPersonalItems.map((item) => (
            <div class="personal-card">
              <span class="personal-card__icon">{item.icon}</span>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </div>
          ))
        }
      </div>

      {
        aboutAdditionalMedia.length > 0 && (
          <div class="photo-strip" aria-label="Additional photos">
            {aboutAdditionalMedia.map((item) => (
              <figure class="photo-slot">
                <img
                  src={resolveMediaSrc(item.src)}
                  alt={item.alt}
                  loading="lazy"
                />
                {item.caption && (
                  <figcaption class="text-mono text-muted">
                    {item.caption}
                  </figcaption>
                )}
              </figure>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- What Matters -->
  <section class="section">
    <div class="container container--sm">
      <SectionHeader
        label="// CORE VALUES"
        title="What Matters to Me"
        centered
      />

      <div class="values-list">
        {
          aboutValues.map((value) => (
            <div class="value-item">
              <span class="value-item__check text-accent" aria-hidden="true">
                ✓
              </span>
              <span>{value}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    resumeConfig && resumePath && (
      <section
        class="section"
        style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);"
      >
        <div class="container container--sm">
          <SectionHeader label="// RESUME" title={resumeConfig.title} />

          <div class="resume-panel panel">
            {resumeConfig.summary && (
              <p class="resume-panel__summary">{resumeConfig.summary}</p>
            )}

            <p class="resume-panel__updated text-mono text-muted">
              Last updated: <span>{resumeConfig.lastUpdated}</span>
            </p>

            <div class="resume-panel__actions">
              <a
                href={resumePath}
                class="btn btn-primary"
                target="_blank"
                rel="noopener noreferrer"
              >
                View Resume
              </a>
              <a href={resumePath} class="btn btn-outline" download>
                Download Resume
              </a>
            </div>
          </div>
        </div>
      </section>
    )
  }
</Layout>

<style>
  .profile-photo {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-md);
  }

  .profile-photo img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
  }

  .resume-panel {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .resume-panel__summary {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .resume-panel__updated {
    margin: 0;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .resume-panel__updated span {
    color: var(--color-text);
  }

  .resume-panel__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  /* Think cards */
  .think-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .think-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .think-card__title {
    font-size: 0.9rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .think-card__text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-xl);
  }

  .skill-group {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .skill-group__header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .skill-group__icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .skill-group__label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .skill-item__dot {
    color: var(--color-accent);
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  /* Personal */
  .personal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-xl);
  }

  .personal-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: border-color var(--transition-base);
  }

  .personal-card:hover {
    border-color: var(--color-border-strong);
  }

  .personal-card__icon {
    display: block;
    font-size: 1.5rem;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    line-height: 1;
  }

  .personal-card h3 {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
  }

  .personal-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .photo-strip {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .photo-slot {
    margin: 0;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .photo-slot img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
  }

  .photo-slot figcaption {
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
  }

  /* Values */
  .values-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .value-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    transition: border-color var(--transition-fast);
  }

  .value-item:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }

  .value-item__check {
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .profile-photo {
      max-width: 320px;
    }

    .think-grid,
    .skills-grid,
    .personal-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .think-card,
    .skill-group,
    .personal-card {
      padding: var(--space-lg);
    }

    .value-item {
      align-items: start;
      padding: var(--space-md);
    }

    .photo-strip {
      grid-template-columns: 1fr;
      margin-top: var(--space-lg);
    }
  }
</style>
