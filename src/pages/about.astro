---
// about.astro — About page
import Layout from "../layouts/Layout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { skillGroups } from "../data/skills";
import {
  aboutBackgroundParagraphs,
  aboutPersonalItems,
  aboutThinkItems,
  aboutValues,
} from "../data/aboutContent";
---

<Layout
  title="About"
  description="Who I am, how I think, how I work, and what matters to me. Background spanning military service, technical program management, community systems, and live event operations."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <p class="section-label">// OPERATOR PROFILE</p>
      <span class="accent-line"></span>
      <h1>About Me</h1>
      <p class="page-hero__sub">
        A systems-minded builder at the intersection of people, process, and technology.
      </p>
    </div>
  </section>

  <!-- Background -->
  <section class="section">
    <div class="container container--md">
      <SectionHeader label="// ORIGIN STORY" title="Background" />

      <div class="prose">
        {aboutBackgroundParagraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- How I Think -->
  <section class="section" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container container--md">
      <SectionHeader label="// MENTAL MODELS" title="How I Think" />

      <div class="think-grid">
        {aboutThinkItems.map((item) => (
          <div class="think-card">
            <h3 class="think-card__title">{item.title}</h3>
            <p class="think-card__text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="section">
    <div class="container">
      <SectionHeader label="// CAPABILITY MATRIX" title="Skills & Expertise" />

      <div class="skills-grid">
        {skillGroups.map((group) => (
          <div class="skill-group">
            <div class="skill-group__header">
              <span class="skill-group__icon text-accent" aria-hidden="true">{group.icon}</span>
              <h3 class="skill-group__label">{group.label}</h3>
            </div>
            <ul class="skill-list">
              {group.skills.map((skill) => (
                <li class="skill-item">
                  <span class="skill-item__dot" aria-hidden="true">▸</span>
                  {skill}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Personal -->
  <section class="section" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container container--md">
      <SectionHeader label="// PERSONAL SYSTEMS" title="Beyond Work" />

      <div class="personal-grid">
        {aboutPersonalItems.map((item) => (
          <div class="personal-card">
            <span class="personal-card__icon">{item.icon}</span>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What Matters -->
  <section class="section">
    <div class="container container--sm">
      <SectionHeader label="// CORE VALUES" title="What Matters to Me" centered />

      <div class="values-list">
        {aboutValues.map((value) => (
          <div class="value-item">
            <span class="value-item__check text-accent" aria-hidden="true">✓</span>
            <span>{value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding-block: var(--space-3xl);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
  }

  .page-hero__sub {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    max-width: 55ch;
    margin-top: var(--space-md);
    margin-bottom: 0;
  }

  .prose p {
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 70ch;
    margin-bottom: var(--space-lg);
  }

  .prose p:last-child { margin-bottom: 0; }

  /* Think cards */
  .think-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .think-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .think-card__title {
    font-size: 0.9rem;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .think-card__text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-xl);
  }

  .skill-group {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .skill-group__header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .skill-group__icon {
    font-size: 1.1rem;
    line-height: 1;
  }

  .skill-group__label {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .skill-item__dot {
    color: var(--color-accent);
    font-size: 0.7rem;
    flex-shrink: 0;
  }

  /* Personal */
  .personal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-xl);
  }

  .personal-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: border-color var(--transition-base);
  }

  .personal-card:hover {
    border-color: var(--color-border-strong);
  }

  .personal-card__icon {
    display: block;
    font-size: 1.5rem;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    line-height: 1;
  }

  .personal-card h3 {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
  }

  .personal-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* Values */
  .values-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .value-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    transition: border-color var(--transition-fast);
  }

  .value-item:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }

  .value-item__check {
    font-size: 0.875rem;
    flex-shrink: 0;
  }
</style>
