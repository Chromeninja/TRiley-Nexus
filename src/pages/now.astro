---
// now.astro — "Now" page (what I'm currently focused on)
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { getActiveProjects } from "../data/projects";
import { toBasePath } from "../utils/paths";
import { siteConfig } from "../data/siteConfig";
import {
  explorationItems,
  nowLastUpdated,
  openToItems,
  priorityItems,
} from "../data/nowContent";

const activeProjects = await getActiveProjects();
const lastUpdated = nowLastUpdated;
---

<Layout
  title="Now"
  description={siteConfig.now.metaDescription}
>
  <!-- Page Hero -->
  <PageHero label="// CURRENT FOCUS" title="What I'm Doing Now">
    <span slot="meta">
      Last updated: {lastUpdated} · Inspired by <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">nownownow.com</a>
    </span>
  </PageHero>

  <!-- Status indicator -->
  <section class="status-banner">
    <div class="container">
      <div class="status-display">
        <span class="status-dot" aria-hidden="true"></span>
        <span class="status-display__primary text-mono">
          {siteConfig.now.statusHeadline}: <span class="text-accent">{siteConfig.now.statusValue}</span>
        </span>
        <span class="status-display__secondary text-mono text-muted">
          {siteConfig.now.statusSupport}
        </span>
      </div>
    </div>
  </section>

  <!-- Active Projects -->
  <section class="section">
    <div class="container">
      <SectionHeader label="// ACTIVE WORKSTREAMS" title="Current Projects" />

      <div class="active-projects">
        {activeProjects.map((project) => (
          <div class="active-project-card">
            <div class="active-project-card__header">
              <div>
                <span class="badge badge-green" style="margin-bottom: var(--space-sm); display: inline-flex;">Active</span>
                <h3 class="active-project-card__title">
                  <a href={`${toBasePath("/projects")}/${project.slug}`}>{project.title}</a>
                </h3>
              </div>
              <span class="badge badge-purple">{project.category}</span>
            </div>
            <p class="active-project-card__summary">{project.summary}</p>
            <div class="active-project-card__meta text-mono text-muted">
              {project.timeframe && <span>{project.timeframe}</span>}
              {project.organization && (
                <span>
                  · {project.organizationUrl ? (
                    <a href={project.organizationUrl} target="_blank" rel="noopener noreferrer">
                      {project.organization}
                    </a>
                  ) : (
                    project.organization
                  )}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Areas of Exploration -->
  <section class="section" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container container--md">
      <SectionHeader label="// EXPLORATION AREAS" title="Areas I'm Exploring" />

      <div class="exploration-grid">
        {explorationItems.map((item) => (
          <div class="explore-card">
            <span class="explore-card__icon text-accent" aria-hidden="true">{item.icon}</span>
            <h3 class="explore-card__title">{item.title}</h3>
            <p class="explore-card__body">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Current Priorities -->
  <section class="section">
    <div class="container container--sm">
      <SectionHeader label="// PRIORITIES" title="Current Priorities" />

      <div class="priority-list">
        {priorityItems.map((item) => (
          <div class="priority-item">
            <span class={`badge ${item.color}`} style="flex-shrink: 0; min-width: 50px; justify-content: center;">{item.label}</span>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What I'm Open To -->
  <section class="section" style="background: var(--color-bg-secondary); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="container container--md">
      <SectionHeader label="// WHAT I'M OPEN TO" title="What I'm Open To" />

      <div class="open-to-grid">
        <div class="open-to-card open-to-card--yes">
          <h3>Yes, please</h3>
          <ul>
            {openToItems.yes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="open-to-card open-to-card--no">
          <h3>Not the right fit</h3>
          <ul>
            {openToItems.no.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>

      <p class="open-to-cta">
        If any of this sounds like what you're looking for, I'd like to hear from you.
        <a href={toBasePath("/contact")} class="btn btn-primary" style="margin-top: var(--space-md); display: inline-flex;">
          Get in Touch
        </a>
      </p>
    </div>
  </section>
</Layout>

<style>
  /* Status banner */
  .status-banner {
    background: rgba(16, 185, 129, 0.05);
    border-bottom: 1px solid rgba(16, 185, 129, 0.15);
    padding-block: var(--space-md);
  }

  .status-display {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse-glow 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .status-display__primary {
    font-size: 0.8rem;
    letter-spacing: 0.06em;
  }

  .status-display__secondary {
    font-size: 0.75rem;
  }

  /* Active projects */
  .active-projects {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .active-project-card {
    background: var(--color-bg-card);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: border-color var(--transition-base);
  }

  .active-project-card:hover {
    border-color: rgba(16, 185, 129, 0.4);
  }

  .active-project-card__header {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: var(--space-lg);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .active-project-card__title {
    font-size: 1.125rem;
    margin: 0;
  }

  .active-project-card__title a {
    color: var(--color-text-heading);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .active-project-card__title a:hover {
    color: var(--color-accent);
  }

  .active-project-card__summary {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
    margin-bottom: var(--space-md);
  }

  .active-project-card__meta {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    display: flex;
    gap: var(--space-sm);
  }

  .active-project-card__meta a {
    color: inherit;
    text-decoration: none;
  }

  .active-project-card__meta a:hover,
  .active-project-card__meta a:focus-visible {
    color: var(--color-accent);
  }

  /* Exploration */
  .exploration-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-xl);
  }

  .explore-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    transition: border-color var(--transition-base);
  }

  .explore-card:hover {
    border-color: var(--color-border-strong);
  }

  .explore-card__icon {
    display: block;
    font-size: 1.4rem;
    margin-bottom: var(--space-md);
    line-height: 1;
  }

  .explore-card__title {
    font-size: 1rem;
    margin-bottom: var(--space-sm);
  }

  .explore-card__body {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* Priority list */
  .priority-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .priority-item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-lg);
  }

  .priority-item p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.4;
  }

  /* Open to */
  .open-to-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .open-to-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .open-to-card--yes {
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .open-to-card--no {
    border: 1px solid var(--color-border);
  }

  .open-to-card h3 {
    font-size: 0.875rem;
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .open-to-card--yes h3 { color: var(--color-success); }
  .open-to-card--no h3 { color: var(--color-text-muted); }

  .open-to-card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .open-to-card li {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    padding-left: var(--space-md);
    position: relative;
  }

  .open-to-card--yes li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--color-success);
    font-size: 0.75rem;
  }

  .open-to-card--no li::before {
    content: "✗";
    position: absolute;
    left: 0;
    color: var(--color-text-dim);
    font-size: 0.75rem;
  }

  .open-to-cta {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .status-display {
      align-items: flex-start;
      gap: var(--space-sm);
    }

    .status-display__primary {
      font-size: 0.76rem;
    }

    .status-display__secondary {
      font-size: 0.72rem;
      line-height: 1.5;
    }

    .active-project-card,
    .explore-card,
    .open-to-card {
      padding: var(--space-lg);
    }

    .active-project-card__meta {
      flex-wrap: wrap;
    }

    .priority-item {
      align-items: start;
      flex-direction: column;
      padding: var(--space-md);
    }

    .open-to-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
