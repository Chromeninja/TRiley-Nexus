---
// projects/index.astro — Projects listing page
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import {
  getProjects,
  getCategories,
  getProjectOrganizationGroups,
  projectStatusColors,
  projectStatusLabels,
  type Project,
} from "../../data/projects";

const categories = await getCategories();
const allProjects = await getProjects();
const organizationGroups = await getProjectOrganizationGroups();
const statusDisplayOrder: Project["status"][] = ["active", "concept", "completed", "archived"];
const usedStatuses = statusDisplayOrder.filter((status) =>
  allProjects.some((project) => project.status === status),
);
---

<Layout
  title="Projects"
  description="Portfolio of projects spanning community systems, operations, automation, infrastructure, program management, and more."
>
  <section class="section">
    <div class="container">
      <SectionHeader
        label="// PROJECT ARCHIVE"
        title="Projects"
        subtitle="Systems I've built, programs I've run, and operations I've led — across community, tech, events, and the military."
      />

      <!-- Filter Bar -->
      <div class="filter-bar" role="group" aria-label="Filter projects by category">
        <button class="filter-btn filter-btn--active" data-filter="all">All</button>
        {categories.map((cat) => (
          <button class="filter-btn" data-filter={cat}>{cat}</button>
        ))}
      </div>

      <!-- Status filter -->
      <div class="status-legend" role="group" aria-label="Filter projects by status">
        <button class="status-filter-btn status-filter-btn--active" data-status-filter="all">All statuses</button>
        {usedStatuses.map((status) => (
          <button
            class={`status-filter-btn ${projectStatusColors[status]}`}
            data-status-filter={status}
          >
            {projectStatusLabels[status]}
          </button>
        ))}
      </div>

      <!-- Organization Groups -->
      <div class="organization-groups" id="projects-grid">
        {organizationGroups.map((group) => (
          <section class="organization-group" data-organization-group>
            <h2 class="organization-group__title text-mono">{group.organization}</h2>
            {(group.companySummary || group.companyInfo || group.myTimeInfo || group.timeRangeLabel) && (
              <div class="organization-group__meta panel">
                {group.companySummary && (
                  <p class="organization-group__summary">{group.companySummary}</p>
                )}
                {group.companyInfo && (
                  <p class="organization-group__description">
                    <span class="text-mono text-accent">Company:</span> {group.companyInfo}
                  </p>
                )}
                {group.myTimeInfo && (
                  <p class="organization-group__description">
                    <span class="text-mono text-accent">My time there:</span> {group.myTimeInfo}
                  </p>
                )}
                {group.timeRangeLabel && (
                  <p class="organization-group__time text-mono text-muted">
                    Timeline: {group.timeRangeLabel}
                  </p>
                )}
              </div>
            )}
            <div class="projects-grid">
              {group.projects.map((project) => (
                <div class="project-item" data-category={project.category} data-status={project.status}>
                  <ProjectCard project={project} />
                </div>
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- Empty state (hidden unless all filtered out) -->
      <div class="empty-state" id="empty-state" hidden>
        <p class="text-muted">No projects found in this category.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3em 0.9em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover,
  .filter-btn--active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .status-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
    align-items: center;
  }

  .status-legend::before {
    content: "Status:";
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-dim);
    letter-spacing: 0.06em;
    margin-right: var(--space-xs);
  }

  .status-filter-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3em 0.9em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .status-filter-btn:hover,
  .status-filter-btn--active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  .organization-groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .organization-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .organization-group__title {
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  .organization-group__meta {
    display: grid;
    gap: var(--space-sm);
    padding: var(--space-lg);
    background: var(--color-bg-secondary);
  }

  .organization-group__summary {
    margin: 0;
    color: var(--color-text);
    line-height: 1.65;
  }

  .organization-group__description {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
    font-size: 0.95rem;
  }

  .organization-group__time {
    margin: 0;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .organization-group--hidden {
    display: none;
  }

  .project-item {
    display: flex;
    flex-direction: column;
  }

  .project-item > * {
    height: 100%;
  }

  .project-item--hidden {
    display: none;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-4xl);
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const statusFilterBtns = document.querySelectorAll<HTMLButtonElement>(".status-filter-btn");
  const projectItems = document.querySelectorAll<HTMLElement>(".project-item");
  const organizationGroups = document.querySelectorAll<HTMLElement>(".organization-group");
  const emptyState = document.getElementById("empty-state");
  let activeCategoryFilter = "all";
  let activeStatusFilter = "all";

  const updateProjectVisibility = () => {
    let visibleCount = 0;

    projectItems.forEach((item) => {
      const category = item.dataset.category ?? "";
      const status = item.dataset.status ?? "";
      const matchesCategory = activeCategoryFilter === "all" || category === activeCategoryFilter;
      const matchesStatus = activeStatusFilter === "all" || status === activeStatusFilter;
      const show = matchesCategory && matchesStatus;

      item.classList.toggle("project-item--hidden", !show);
      if (show) {
        visibleCount++;
      }
    });

    organizationGroups.forEach((group) => {
      const visibleProjectsInGroup = group.querySelectorAll(".project-item:not(.project-item--hidden)").length;
      group.classList.toggle("organization-group--hidden", visibleProjectsInGroup === 0);
    });

    if (emptyState) {
      emptyState.hidden = visibleCount > 0;
    }
  };

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeCategoryFilter = btn.dataset.filter ?? "all";

      filterBtns.forEach((b) => b.classList.remove("filter-btn--active"));
      btn.classList.add("filter-btn--active");

      updateProjectVisibility();
    });
  });

  statusFilterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeStatusFilter = btn.dataset.statusFilter ?? "all";

      statusFilterBtns.forEach((button) => button.classList.remove("status-filter-btn--active"));
      btn.classList.add("status-filter-btn--active");

      updateProjectVisibility();
    });
  });

  updateProjectVisibility();
</script>
