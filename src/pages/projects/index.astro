---
// projects/index.astro — Projects listing page
import Layout from "../../layouts/Layout.astro";
import CareerNarrativeExplorer from "../../components/CareerNarrativeExplorer.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import {
  getCareerNarrativeData,
  getCategories,
  projectStatusColors,
  projectStatusLabels,
  type Project,
} from "../../data/projects";

const categories = await getCategories();
const careerNarrativeData = await getCareerNarrativeData();
const statusDisplayOrder: Project["status"][] = ["active", "concept", "completed", "archived"];
const usedStatuses = statusDisplayOrder.filter((status) =>
  careerNarrativeData.companies.some((company) => company.projects.some((project) => project.status === status)),
);
---

<Layout
  title="Projects"
  description="Portfolio of projects spanning community systems, operations, automation, infrastructure, program management, and more."
>
  <section class="section">
    <div class="container">
      <SectionHeader
        label="// PROJECT ARCHIVE"
        title="Projects"
        subtitle="Browse the archive the same way the work actually happened: by company, with projects nested inline and filters layered on top."
      />

      <!-- Filter Bar -->
      <div class="filter-bar" role="group" aria-label="Filter projects by category">
        <button class="filter-btn filter-btn--active" data-filter="all">All</button>
        {categories.map((cat) => (
          <button class="filter-btn" data-filter={cat}>{cat}</button>
        ))}
      </div>

      <!-- Status filter -->
      <div class="status-legend" role="group" aria-label="Filter projects by status">
        <button class="status-filter-btn status-filter-btn--active" data-status-filter="all">All statuses</button>
        {usedStatuses.map((status) => (
          <button
            class={`status-filter-btn ${projectStatusColors[status]}`}
            data-status-filter={status}
          >
            {projectStatusLabels[status]}
          </button>
        ))}
      </div>

      <div id="projects-grid">
        <CareerNarrativeExplorer
          data={careerNarrativeData}
          label="// ARCHIVE VIEW"
          title="Company-first archive"
          subtitle="Use filters to narrow the view, but keep the chronology and company context intact while exploring."
          showControls={false}
          compact
        />
      </div>

      <!-- Empty state (hidden unless all filtered out) -->
      <div class="empty-state" id="empty-state" hidden>
        <p class="text-muted">No projects found in this category.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3em 0.9em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover,
  .filter-btn--active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .status-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
    align-items: center;
  }

  .status-legend::before {
    content: "Status:";
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-dim);
    letter-spacing: 0.06em;
    margin-right: var(--space-xs);
  }

  .status-filter-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3em 0.9em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .status-filter-btn:hover,
  .status-filter-btn--active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-4xl);
  }

  @media (max-width: 640px) {
    .filter-bar,
    .status-legend {
      gap: var(--space-xs);
    }

    .filter-btn,
    .status-filter-btn {
      font-size: 0.74rem;
      letter-spacing: 0.05em;
      padding: 0.44rem 0.72rem;
    }

    .status-legend::before {
      width: 100%;
      margin-right: 0;
      margin-bottom: 0.3rem;
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const statusFilterBtns = document.querySelectorAll<HTMLButtonElement>(".status-filter-btn");
  const projectItems = document.querySelectorAll<HTMLElement>(".narrative-project");
  const companyItems = document.querySelectorAll<HTMLElement>(".narrative-company");
  const emptyState = document.getElementById("empty-state");
  let activeCategoryFilter = "all";
  let activeStatusFilter = "all";

  const updateProjectVisibility = () => {
    let visibleCount = 0;

    projectItems.forEach((item) => {
      const category = item.dataset.category ?? "";
      const status = item.dataset.status ?? "";
      const matchesCategory = activeCategoryFilter === "all" || category === activeCategoryFilter;
      const matchesStatus = activeStatusFilter === "all" || status === activeStatusFilter;
      const show = matchesCategory && matchesStatus;

      item.classList.toggle("narrative-project--hidden", !show);
      if (show) {
        visibleCount++;
      }
    });

    companyItems.forEach((company) => {
      const visibleProjects = company.querySelectorAll(".narrative-project:not(.narrative-project--hidden)");
      company.classList.toggle("narrative-company--hidden", visibleProjects.length === 0);
    });

    if (emptyState) {
      emptyState.hidden = visibleCount > 0;
    }
  };

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeCategoryFilter = btn.dataset.filter ?? "all";

      filterBtns.forEach((b) => b.classList.remove("filter-btn--active"));
      btn.classList.add("filter-btn--active");

      updateProjectVisibility();
    });
  });

  statusFilterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeStatusFilter = btn.dataset.statusFilter ?? "all";

      statusFilterBtns.forEach((button) => button.classList.remove("status-filter-btn--active"));
      btn.classList.add("status-filter-btn--active");

      updateProjectVisibility();
    });
  });

  updateProjectVisibility();
</script>
