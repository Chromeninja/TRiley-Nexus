---
// projects/index.astro — Projects listing page
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import {
  getProjects,
  getCategories,
  projectStatusColors,
  projectStatusLabels,
  type Project,
} from "../../data/projects";

const categories = await getCategories();
const allProjects = await getProjects();
const statusDisplayOrder: Project["status"][] = ["active", "concept", "completed", "archived"];
const usedStatuses = statusDisplayOrder.filter((status) =>
  allProjects.some((project) => project.status === status),
);

function parseProjectDate(value: string | undefined, boundary: "start" | "end"): Date | undefined {
  if (!value) return undefined;

  const trimmed = value.trim();
  const match = /^(\w+)\s+(\d{4})$/i.exec(trimmed);
  if (match) {
    const monthLookup: Record<string, number> = {
      jan: 0,
      feb: 1,
      mar: 2,
      apr: 3,
      may: 4,
      jun: 5,
      jul: 6,
      aug: 7,
      sep: 8,
      oct: 9,
      nov: 10,
      dec: 11,
    };

    const month = monthLookup[match[1].slice(0, 3).toLowerCase()];
    if (month === undefined) return undefined;

    const year = Number.parseInt(match[2], 10);
    const day = boundary === "start" ? 1 : new Date(year, month + 1, 0).getDate();
    return new Date(year, month, day);
  }

  const yearOnly = /^(\d{4})$/.exec(trimmed);
  if (yearOnly) {
    const year = Number.parseInt(yearOnly[1], 10);
    return boundary === "start" ? new Date(year, 0, 1) : new Date(year, 11, 31);
  }

  return undefined;
}

function getProjectSortDate(project: Project): number {
  const endedAt = parseProjectDate(project.endedAt, "end");
  if (endedAt) return endedAt.getTime();

  if (project.status === "active" || project.status === "concept") {
    return Date.now();
  }

  const startedAt = parseProjectDate(project.startedAt, "start");
  if (startedAt) return startedAt.getTime();

  return 0;
}

const sortedProjects = [...allProjects].sort((a, b) => getProjectSortDate(b) - getProjectSortDate(a));
---

<Layout
  title="Projects"
  description="Portfolio of projects spanning community systems, operations, automation, infrastructure, program management, and more."
>
  <section class="section">
    <div class="container">
      <SectionHeader
        label="// PROJECT ARCHIVE"
        title="Projects"
        subtitle="Systems I've built, programs I've run, and operations I've led — across community, tech, events, and the military."
      />

      <!-- Filter Bar -->
      <div class="filter-bar" role="group" aria-label="Filter projects by category">
        <button class="filter-btn filter-btn--active" data-filter="all">All</button>
        {categories.map((cat) => (
          <button class="filter-btn" data-filter={cat}>{cat}</button>
        ))}
      </div>

      <!-- Status filter -->
      <div class="status-legend" role="group" aria-label="Filter projects by status">
        <button class="status-filter-btn status-filter-btn--active" data-status-filter="all">All statuses</button>
        {usedStatuses.map((status) => (
          <button
            class={`status-filter-btn ${projectStatusColors[status]}`}
            data-status-filter={status}
          >
            {projectStatusLabels[status]}
          </button>
        ))}
      </div>

      <div class="projects-grid" id="projects-grid">
        {sortedProjects.map((project) => (
          <div class="project-item" data-category={project.category} data-status={project.status}>
            <ProjectCard project={project} />
          </div>
        ))}
      </div>

      <!-- Empty state (hidden unless all filtered out) -->
      <div class="empty-state" id="empty-state" hidden>
        <p class="text-muted">No projects found in this category.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3em 0.9em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .filter-btn:hover,
  .filter-btn--active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .status-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-2xl);
    align-items: center;
  }

  .status-legend::before {
    content: "Status:";
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-dim);
    letter-spacing: 0.06em;
    margin-right: var(--space-xs);
  }

  .status-filter-btn {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.3em 0.9em;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .status-filter-btn:hover,
  .status-filter-btn--active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-xl);
  }

  .project-item {
    display: flex;
    flex-direction: column;
  }

  .project-item > * {
    height: 100%;
  }

  .project-item--hidden {
    display: none;
  }

  .empty-state {
    text-align: center;
    padding: var(--space-4xl);
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const statusFilterBtns = document.querySelectorAll<HTMLButtonElement>(".status-filter-btn");
  const projectItems = document.querySelectorAll<HTMLElement>(".project-item");
  const emptyState = document.getElementById("empty-state");
  let activeCategoryFilter = "all";
  let activeStatusFilter = "all";

  const updateProjectVisibility = () => {
    let visibleCount = 0;

    projectItems.forEach((item) => {
      const category = item.dataset.category ?? "";
      const status = item.dataset.status ?? "";
      const matchesCategory = activeCategoryFilter === "all" || category === activeCategoryFilter;
      const matchesStatus = activeStatusFilter === "all" || status === activeStatusFilter;
      const show = matchesCategory && matchesStatus;

      item.classList.toggle("project-item--hidden", !show);
      if (show) {
        visibleCount++;
      }
    });

    if (emptyState) {
      emptyState.hidden = visibleCount > 0;
    }
  };

  filterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeCategoryFilter = btn.dataset.filter ?? "all";

      filterBtns.forEach((b) => b.classList.remove("filter-btn--active"));
      btn.classList.add("filter-btn--active");

      updateProjectVisibility();
    });
  });

  statusFilterBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      activeStatusFilter = btn.dataset.statusFilter ?? "all";

      statusFilterBtns.forEach((button) => button.classList.remove("status-filter-btn--active"));
      btn.classList.add("status-filter-btn--active");

      updateProjectVisibility();
    });
  });

  updateProjectVisibility();
</script>
