---
// projects/index.astro — Projects listing page
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { getProjectsPageData } from "../../data/projects";

const projectsPageData = await getProjectsPageData(6);
---

<Layout
  title="Projects"
  description="Portfolio of projects spanning community systems, operations, automation, infrastructure, program management, and more."
>
  <section class="section">
    <div class="container">
      <SectionHeader
        label="// PROJECTS"
        title="Projects"
        subtitle="Featured work first, then the full catalog grouped by category so you can scan quickly and dive deeper where needed."
      />

      <div class="projects-topline panel" aria-label="Projects summary">
        <p class="projects-topline__intro">
          {projectsPageData.totalProjectCount} total projects. Start with the featured
          set, then browse the full list by category.
        </p>
        <div class="projects-topline__chips" aria-label="Project categories">
          {
            projectsPageData.categoryGroups.map((group) => (
              <a
                href={`#category-${group.category.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}
                class="projects-chip"
              >
                {group.category} <span>{group.projects.length}</span>
              </a>
            ))
          }
        </div>
      </div>

      <section
        class="projects-section"
        aria-labelledby="featured-projects-heading"
      >
        <div class="projects-section__header">
          <p class="projects-section__label text-mono">01 // Featured</p>
          <h2 id="featured-projects-heading" class="projects-section__title">
            Most relevant recent work
          </h2>
        </div>

        <div class="projects-grid">
          {
            projectsPageData.featuredProjects.map((project) => (
              <ProjectCard project={project} featured />
            ))
          }
        </div>
      </section>

      {
        projectsPageData.categoryGroups.map((group, index) => {
          const sectionId = `category-${group.category.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;

          return (
            <section class="projects-section" aria-labelledby={sectionId}>
              <div class="projects-section__header">
                <p class="projects-section__label text-mono">
                  {String(index + 2).padStart(2, "0")} // {group.category}
                </p>
                <h2 id={sectionId} class="projects-section__title">
                  {group.category}
                </h2>
              </div>

              <div class="projects-grid">
                {group.projects.map((project) => (
                  <ProjectCard project={project} />
                ))}
              </div>
            </section>
          );
        })
      }
    </div>
  </section>
</Layout>

<style>
  .projects-topline {
    margin-bottom: var(--space-2xl);
    display: grid;
    gap: var(--space-md);
  }

  .projects-topline__intro {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .projects-topline__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .projects-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.38rem 0.74rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast),
      background var(--transition-fast);
  }

  .projects-chip:hover,
  .projects-chip:focus-visible {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .projects-chip span {
    color: var(--color-text-dim);
  }

  .projects-section {
    margin-top: var(--space-3xl);
  }

  .projects-section__header {
    margin-bottom: var(--space-lg);
  }

  .projects-section__label {
    margin: 0 0 var(--space-xs);
    color: var(--color-text-dim);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .projects-section__title {
    margin: 0;
    font-size: clamp(1.25rem, 2.2vw, 1.75rem);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: var(--space-lg);
  }

  @media (max-width: 640px) {
    .projects-topline {
      margin-bottom: var(--space-xl);
      padding: var(--space-lg);
    }

    .projects-section {
      margin-top: var(--space-2xl);
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
</style>
